# Copy to .env for local runs: cp .env.example .env
# The real .env is gitignored — never commit your key.

# Required: your Bayse public key (pk_live_...), sent as the X-Public-Key header.
BAYSE_PUBLIC_KEY=pk_live_your_key_here

# Required: Postgres DSN. docker compose sets this for you; this value is for
# running the binary directly against a local Postgres.
DATABASE_URL=postgres://bayse:bayse@localhost:5432/bayse?sslmode=disable

# Optional — sensible defaults shown.
# BAYSE_BASE_URL=https://relay.bayse.markets/v1/pm
# POLL_INTERVAL=10s
# HTTP_ADDR=:8080
# HTTP_TIMEOUT=5s
